# ACI-BR — Configuração de Ambiente
# Copie para .env e preencha com seus valores

APP_NAME=ACI-BR
DEBUG=true
SECRET_KEY=CHANGE_ME_USE_openssl_rand_hex_32
JWT_SECRET=CHANGE_ME_JWT_SECRET
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

POSTGRES_URL=postgresql+asyncpg://postgres:password@localhost:5432/aci_db
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=aci_staging

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=sa-east-1
AUDIO_STORAGE_BUCKET=aci-audio-encrypted

HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WHISPER_MODEL=large-v3
DIARIZATION_MODEL=pyannote/speaker-diarization-3.1
NER_MODEL=pucpr/biobertpt-clin

VITE_API_URL=http://localhost:8001
VITE_WS_URL=ws://localhost:8001/audio/stream
